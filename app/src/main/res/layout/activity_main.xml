<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080808"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111111"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_edit_page"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="PAGE EDIT"
            android:textSize="12sp"
            android:backgroundTint="#00DD00"
            android:textColor="#000000"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_display"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="#0A0A0A"
            android:text="PA... EDIT"
            android:textColor="#DDDDDD"
            android:gravity="center_vertical|start"
            android:paddingStart="8dp" />

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="#FF0000" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:weightSum="4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2">
            <Button android:id="@+id/btn_crash" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="8dp" android:text="CRASH" android:textSize="18sp" android:textStyle="bold|italic" android:gravity="bottom|start" android:padding="16dp" android:backgroundTint="#222222" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btn_tom" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="8dp" android:text="TOM" android:textSize="18sp" android:textStyle="bold|italic" android:gravity="bottom|start" android:padding="16dp" android:backgroundTint="#222222" android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2">
            <Button android:id="@+id/btn_rim" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="8dp" android:text="RIM" android:textSize="18sp" android:textStyle="bold|italic" android:gravity="bottom|start" android:padding="16dp" android:backgroundTint="#222222" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btn_clap" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="8dp" android:text="CLAP" android:textSize="18sp" android:textStyle="bold|italic" android:gravity="bottom|start" android:padding="16dp" android:backgroundTint="#222222" android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2">
            <Button android:id="@+id/btn_kick" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="8dp" android:text="KICK" android:textSize="18sp" android:textStyle="bold|italic" android:gravity="bottom|start" android:padding="16dp" android:backgroundTint="#222222" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btn_snare" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="8dp" android:text="SNARE" android:textSize="18sp" android:textStyle="bold|italic" android:gravity="bottom|start" android:padding="16dp" android:backgroundTint="#222222" android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2">
            <Button android:id="@+id/btn_ohat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="8dp" android:text="O-HAT" android:textSize="18sp" android:textStyle="bold|italic" android:gravity="bottom|start" android:padding="16dp" android:backgroundTint="#222222" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btn_chat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="8dp" android:text="C-HAT" android:textSize="18sp" android:textStyle="bold|italic" android:gravity="bottom|start" android:padding="16dp" android:backgroundTint="#222222" android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
